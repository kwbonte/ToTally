@page "/teams"
@using ToTally.Application.DTOs.Teams
@using ToTally.Application.Interfaces
@inject ITeamService TeamService

<h3>Teams</h3>

@if (_isLoading)
{
    <p>Loading teams...</p>
}
else if (_teams.Count == 0)
{
    <p>No teams found.</p>
}
else
{
    <p>
        Showing @_teams.Count team(s).
    </p>

    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Team</th>
                <th>Abbr</th>
                <th>League</th>
                <th>Conference</th>
                <th>Division</th>
                <th>Venue</th>
                <th>Venue Location</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var team in _teams)
            {
                <tr>
                    <td>@team.DisplayName</td>
                    <td>@team.Abbreviation</td>
                    <td>@team.LeagueAbbreviation</td>
                    <td>@team.ConferenceAbbreviation</td>
                    <td>@team.DivisionName</td>
                    <td>@team.VenueName</td>
                    <td>@team.VenueCity, @team.VenueStateOrCountry</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<TeamListItem> _teams = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _teams = await TeamService.GetAllTeamDumpAsync();
        _isLoading = false;
    }
}